  "item": [
    {
      "name": "CT01 - FB - Cadastrar usuário com sucesso",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Mensagem de sucesso deve ser validada\", function () {\r",
              "    pm.expect(response.message).to.eql(\"Cadastro realizado com sucesso\");\r",
              "});\r",
              "\r",
              "pm.test(\"Deve retornar o ID do usuário cadastrado\", function () {\r",
              "    pm.expect(response).to.have.property(\"_id\");\r",
              "    pm.expect(response._id).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"nome\": \"Usuario QA {{$timestamp}}\",\r\n  \"email\": \"qa{{$timestamp}}@teste.com\",\r\n  \"password\": \"teste123\",\r\n  \"administrador\": \"true\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios"
          ]
        }
      },
      "response": []
    },
    {
      "name": "CT02 - FA - Listar usuários cadastrados",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Deve retornar o campo quantidade\", function () {\r",
              "    pm.expect(response).to.have.property(\"quantidade\");\r",
              "    pm.expect(response.quantidade).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "pm.test(\"Deve retornar uma lista de usuários\", function () {\r",
              "    pm.expect(response).to.have.property(\"usuarios\");\r",
              "    pm.expect(response.usuarios).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Cada usuário deve possuir campos mínimos esperados\", function () {\r",
              "    response.usuarios.forEach(function (usuario) {\r",
              "        pm.expect(usuario).to.have.property(\"nome\");\r",
              "        pm.expect(usuario).to.have.property(\"email\");\r",
              "        pm.expect(usuario).to.have.property(\"password\");\r",
              "        pm.expect(usuario).to.have.property(\"administrador\");\r",
              "        pm.expect(usuario).to.have.property(\"_id\");\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios"
          ]
        }
      },
      "response": []
    },
    {
      "name": "CT03 - Setup - Criar usuário para duplicidade",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Setup deve cadastrar usuário para teste de duplicidade\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "const requestBody = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "pm.collectionVariables.set(\"usuarioDuplicadoNome\", requestBody.nome);\r",
              "pm.collectionVariables.set(\"usuarioDuplicadoEmail\", requestBody.email);\r",
              "pm.collectionVariables.set(\"usuarioDuplicadoPassword\", requestBody.password);\r",
              "pm.collectionVariables.set(\"usuarioDuplicadoAdministrador\", requestBody.administrador);\r",
              "pm.collectionVariables.set(\"usuarioDuplicadoId\", response._id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"nome\": \"Usuario QA {{$timestamp}}\",\r\n  \"email\": \"duplicado{{$timestamp}}@teste.com\",\r\n  \"password\": \"teste123\",\r\n  \"administrador\": \"true\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios"
          ]
        }
      },
      "response": []
    },
