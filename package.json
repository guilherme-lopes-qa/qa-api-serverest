{
  "name": "qa-api-serverest",
  "version": "1.0.0",
  "description": "Automação de testes de API ServeRest com Cypress e Gherkin",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf cypress/screenshots cypress/videos cypress/downloads cypress/reports cypress/results docs",
    "test": "cypress run",
    "test:open": "cypress open",
    "test:usuarios": "cypress run --spec cypress/e2e/features/usuarios.feature",
    "report": "node scripts/report.js",
    "clean:test": "npm run clean && npm test && npm run report"
  },
  "keywords": [
    "qa",
    "cypress",
    "api",
    "gherkin",
    "serverest"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.14.2",
    "rimraf": "^6.1.3"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/support/step_definitions/**/*.js"
    ]
  }
}